{
  "id": "ankicli",
  "skills": ["skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "ankicliPath": {
        "type": "string",
        "description": "Path to the ankicli executable. Defaults to 'ankicli'."
      },
      "backend": {
        "type": "string",
        "enum": ["python-anki", "ankiconnect"],
        "description": "Optional ankicli backend override."
      },
      "toolMode": {
        "type": "string",
        "enum": [
          "llm-default",
          "primary-only",
          "legacy-low-level",
          "expert-only",
          "all",
          "passthrough-only",
          "curated-only"
        ],
        "description": "Controls whether the plugin registers the primary study-oriented surface, the legacy low-level surface, the expert passthrough, or all of them."
      },
      "collectionPath": {
        "type": "string",
        "description": "Optional default collection path passed as --collection."
      },
      "ankiconnectUrl": {
        "type": "string",
        "description": "Optional ANKICONNECT_URL override for ankicli."
      }
    }
  }
}
