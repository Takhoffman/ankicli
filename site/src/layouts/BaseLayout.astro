---
const {
  title = "ankicli",
  description = "Local-first, automation-grade Anki collection management CLI.",
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => new URL(path, `https://takhoffman.github.io${basePath}`).pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #050816;
        --panel: rgba(9, 15, 34, 0.82);
        --panel-strong: #0e1531;
        --text: #f8f6ef;
        --muted: #b7bfd9;
        --lime: #9cff4f;
        --pink: #ff56cf;
        --yellow: #ffe15d;
        --line: rgba(255, 255, 255, 0.12);
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(156, 255, 79, 0.18), transparent 28%),
          radial-gradient(circle at top right, rgba(255, 86, 207, 0.18), transparent 30%),
          linear-gradient(180deg, #091126 0%, #050816 100%);
      }
      a { color: inherit; }
      .shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(18px);
        background: rgba(5, 8, 22, 0.75);
        border-bottom: 1px solid var(--line);
      }
      .nav {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        font-weight: 800;
        letter-spacing: 0.03em;
      }
      .brand-badge {
        width: 2rem;
        height: 2rem;
        display: inline-grid;
        place-items: center;
        color: #061117;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, var(--lime), #d9ff66);
        box-shadow: var(--shadow);
      }
      .nav-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .nav-links a {
        text-decoration: none;
        color: var(--muted);
      }
      main {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2.5rem 0 5rem;
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 1.5rem;
        box-shadow: var(--shadow);
      }
      code, pre {
        font-family: "SFMono-Regular", ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      pre {
        padding: 1rem;
        overflow: auto;
        background: rgba(0, 0, 0, 0.32);
        border-radius: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .eyebrow {
        color: var(--lime);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-weight: 700;
      }
      h1, h2, h3 { line-height: 1.05; margin: 0; }
      p { color: var(--muted); line-height: 1.6; }
      .footer {
        max-width: 1200px;
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 0 0 3rem;
        color: var(--muted);
      }
      .docs-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .docs-grid .card {
        padding: 1.2rem;
      }
      @media (max-width: 760px) {
        .nav { align-items: flex-start; flex-direction: column; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header>
        <div class="nav">
          <a class="brand" href={baseUrl}>
            <span class="brand-badge">&gt;_</span>
            <span>ankicli</span>
          </a>
          <nav class="nav-links">
            <a href={withBase("install")}>Install</a>
            <a href={withBase("docs/quickstart")}>Docs</a>
            <a href="https://github.com/Takhoffman/ankicli/releases">Releases</a>
            <a href="https://github.com/Takhoffman/ankicli">GitHub</a>
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <p>ankicli is a local-first CLI for managing Anki collections from your terminal, scripts, and agents.</p>
      </footer>
    </div>
  </body>
</html>
