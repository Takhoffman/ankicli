---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstallCards from "../components/InstallCards.astro";
import { issuesUrl, releasesUrl, repoUrl } from "../lib/install";
const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;
const withBase = (path: string) => new URL(path, `https://takhoffman.github.io${basePath}`).pathname;
---

<BaseLayout title="ankicli | Learn smart from your terminal">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Install it. verify it. hand it to your agent.</p>
      <h1>Put a safe, scriptable Anki control surface in front of your agent harness.</h1>
      <p>
        ankicli is a local-first Anki CLI for smart, semi-technical operators who want a real
        product they can install once, verify quickly, and then hand off to Claude, Codex,
        OpenClaw, or their own scripts.
      </p>
      <p class="operator-note">
        Installed by humans. Operated by agents. Supervised with explicit JSON output, dry-run
        support, and safety-first write flows.
      </p>
      <div class="hero-actions">
        <a class="primary" href={withBase("install")}>Install ankicli</a>
        <a class="secondary" href={withBase("docs/quickstart")}>Read the quickstart</a>
      </div>
      <div class="hero-links">
        <a href={releasesUrl}>Releases</a>
        <a href={repoUrl}>Source</a>
        <a href={issuesUrl}>Issues</a>
      </div>
    </div>
    <div class="hero-art card">
      <img src={withBase("ankicli-hero.png")} alt="ankicli hero art" />
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Install</p>
        <h2>Copy one command for your platform</h2>
      </div>
      <p>The first-party installers download standalone release artifacts, verify checksums, install to a user-local path, and run a post-install health check.</p>
    </div>
    <InstallCards />
  </section>

  <section class="section workflow">
    <div class="section-head">
      <div>
        <p class="eyebrow">Workflow</p>
        <h2>How ankicli fits into a real operator workflow</h2>
      </div>
    </div>
    <div class="docs-grid">
      <div class="card link-card">
        <h3>1. Install and verify as a human</h3>
        <p>Run the platform installer, confirm the runtime is healthy, and resolve the right Anki profile before any real collection work.</p>
      </div>
      <div class="card link-card">
        <h3>2. Hand stable docs to your agent</h3>
        <p>Use the docs pages and their Copy Page buttons to paste structured context directly into Claude, Codex, or OpenClaw.</p>
      </div>
      <div class="card link-card">
        <h3>3. Let the agent operate safely</h3>
        <p>Use JSON output, dry-run-first mutation flows, explicit confirms, backups, and sync preflight instead of ad hoc terminal hacks.</p>
      </div>
    </div>
  </section>

  <section class="docs-grid section">
    <a class="card link-card" href={withBase("docs/bundled-skills")}>
      <p class="card-kicker">Bundles</p>
      <h3>Skill folders and install targets</h3>
      <p>Open the shipped GitHub bundle for Codex, Claude Code, or OpenClaw, or grab the exact install command for your local skills home.</p>
    </a>
    <a class="card link-card" href={withBase("docs/learning-plans")}>
      <p class="card-kicker">Study systems</p>
      <h3>Learning plans</h3>
      <p>Goal-driven study for travel, anime immersion, medical exams, and time-bounded progress.</p>
    </a>
    <a class="card link-card" href={withBase("docs/recipes")}>
      <p class="card-kicker">Workflows</p>
      <h3>Recipes</h3>
      <p>Mechanics for image generation, TTS enrichment, source-to-deck workflows, and repair flows.</p>
    </a>
    <a class="card link-card" href={withBase("docs/cli-guide")}>
      <p class="card-kicker">Reference</p>
      <h3>CLI guide</h3>
      <p>Command shape, targeting flags, help output, JSON mode, and safety switches.</p>
    </a>
    <a class="card link-card" href={withBase("docs/common-tasks")}>
      <p class="card-kicker">Commands</p>
      <h3>Common tasks</h3>
      <p>Exact commands for inspection, search, note changes, backup, sync, and study.</p>
    </a>
    <a class="card link-card" href={withBase("docs/profiles-and-collections")}>
      <p class="card-kicker">Targeting</p>
      <h3>Profiles and collections</h3>
      <p>Use profile-aware commands or point directly at a collection file.</p>
    </a>
    <a class="card link-card" href={withBase("docs/sync-and-backups")}>
      <p class="card-kicker">Safety</p>
      <h3>Sync and backups</h3>
      <p>Safe preflight, stored credentials, and local backup recovery flows.</p>
    </a>
    <a class="card link-card" href={withBase("docs/study")}>
      <p class="card-kicker">Sessions</p>
      <h3>Study mode</h3>
      <p>Run local tutor-style sessions without turning the CLI into a fragile TUI.</p>
    </a>
    <a class="card link-card" href={withBase("docs/troubleshooting")}>
      <p class="card-kicker">Diagnostics</p>
      <h3>Troubleshooting</h3>
      <p>Debug install issues, runtime validation failures, and profile resolution problems.</p>
    </a>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Verify</p>
        <h2>Health check after install</h2>
      </div>
    </div>
    <div class="card verify">
      <pre><code>ankicli --version
ankicli --json doctor env
ankicli --json doctor backend</code></pre>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    margin-bottom: 3rem;
  }
  .hero-copy h1 {
    margin-top: 0.5rem;
    font-size: clamp(2.6rem, 5vw, 5rem);
  }
  .hero-actions, .hero-links {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }
  .operator-note {
    max-width: 60ch;
  }
  .primary, .secondary, .link-card {
    text-decoration: none;
  }
  .primary, .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    font-weight: 700;
  }
  .primary {
    color: #081014;
    background: linear-gradient(135deg, var(--lime), #d3ff6c);
  }
  .secondary {
    border: 1px solid var(--line);
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }
  .hero-links a { color: var(--muted); }
  .hero-art { padding: 1rem; }
  .hero-art img {
    width: 100%;
    display: block;
    border-radius: 1rem;
  }
  .section {
    margin-top: 2rem;
  }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .link-card {
    display: grid;
    align-content: start;
    gap: 0.65rem;
    min-height: 13.5rem;
    padding: 1.35rem;
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.018)),
      linear-gradient(135deg, rgba(156, 255, 79, 0.06), rgba(255, 86, 207, 0.03)),
      rgba(8, 12, 28, 0.9);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease;
  }
  .link-card:link,
  .link-card:visited {
    color: var(--text);
  }
  .link-card:hover {
    transform: translateY(-4px);
    border-color: rgba(156, 255, 79, 0.3);
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
  }
  .link-card:focus-visible {
    outline: 2px solid rgba(156, 255, 79, 0.9);
    outline-offset: 3px;
    border-color: rgba(156, 255, 79, 0.4);
  }
  .link-card h3 {
    font-size: clamp(1.4rem, 2vw, 1.8rem);
    line-height: 1.08;
    color: var(--text);
  }
  .link-card p {
    margin: 0;
    max-width: 32ch;
    color: var(--muted);
  }
  .card-kicker {
    color: var(--lime);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .workflow .link-card {
    text-decoration: none;
  }
  .verify {
    padding: 1rem;
  }
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .section-head {
      flex-direction: column;
      align-items: start;
    }
  }
</style>
